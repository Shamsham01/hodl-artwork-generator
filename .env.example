# Basturds NFT Generator - Environment Variables
# Copy to .env and fill in values for each service

# ── Frontend (Netlify recommended — set these in Netlify UI, not in git) ──
# Copy to apps/web/.env for local dev. Generation runs in the browser.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_MVX_ENV=mainnet
VITE_WALLETCONNECT_V2_PROJECT_ID=

# Generation fee (MultiversX mainnet USDC). Wallet must be on mainnet (VITE_MVX_ENV=mainnet).
# VITE_GENERATION_PAYMENT_TOKEN=USDC-c76f1f
# VITE_GENERATION_PAYMENT_TREASURY=erd158k2c3aserjmwnyxzpln24xukl2fsvlk9x46xae4dxl5xds79g6sdz37qn
# VITE_GENERATION_PAYMENT_DECIMALS=6
# VITE_GENERATION_PAYMENT_API_URL=https://api.multiversx.com
# VITE_GENERATION_PAYMENT_DISABLED=true

# ── Cybrancee (optional — skip if using Netlify only) ──
# npm run package:cybrancee  → upload deploy/cybrancee/out/

# ── Supabase Edge Function secrets (Dashboard → Edge Functions → Secrets) ──
# MVX_ALLOWED_ORIGINS=https://hodl-artwork-generator.netlify.app,https://your-domain.com,http://localhost:5173
# MVX_ENV=mainnet
GENERATION_PAYMENT_TOKEN=USDC-c76f1f
GENERATION_PAYMENT_TREASURY=erd158k2c3aserjmwnyxzpln24xukl2fsvlk9x46xae4dxl5xds79g6sdz37qn
GENERATION_PAYMENT_DECIMALS=6
GENERATION_PAYMENT_API_URL=https://api.multiversx.com
# GENERATION_PAYMENT_DISABLED=true
MAX_EDITION_SIZE=10000

# ── Legacy API (optional stub — decommission Render to save cost) ──
# PORT=3001


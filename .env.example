# Basturds NFT Generator - Environment Variables
# Copy to .env and fill in values for each service

# ── Frontend (Netlify / Vite) ──
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:3001
VITE_MVX_ENV=devnet
VITE_WALLETCONNECT_V2_PROJECT_ID=

# Generation fee (MultiversX mainnet USDC). Wallet must be on mainnet (VITE_MVX_ENV=mainnet).
# VITE_GENERATION_PAYMENT_TOKEN=USDC-c76f1f
# VITE_GENERATION_PAYMENT_TREASURY=erd158k2c3aserjmwnyxzpln24xukl2fsvlk9x46xae4dxl5xds79g6sdz37qn
# VITE_GENERATION_PAYMENT_DECIMALS=6
# VITE_GENERATION_PAYMENT_API_URL=https://api.multiversx.com
# VITE_GENERATION_PAYMENT_DISABLED=true

# ── API (Render) ──
PORT=3001
NODE_ENV=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
FRONTEND_URL=http://localhost:5173
MVX_NATIVE_AUTH_ORIGIN=http://localhost:5173
MVX_API_DEVNET=https://devnet-api.multiversx.com
MVX_API_TESTNET=https://testnet-api.multiversx.com
MVX_API_MAINNET=https://api.multiversx.com
MAX_EDITION_SIZE=10000
MAX_CONCURRENT_JOBS=3
JOB_TIMEOUT_MS=3600000

# ── Supabase Edge Functions ──
MVX_ALLOWED_ORIGINS=http://localhost:5173
MVX_ENV=devnet

# ── Production examples ──
# VITE_API_URL=https://your-api.onrender.com
# FRONTEND_URL=https://your-app.netlify.app
# MVX_ALLOWED_ORIGINS=https://your-app.netlify.app

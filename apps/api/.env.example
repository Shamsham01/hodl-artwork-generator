# ─────────────────────────────────────────────────────────────
# HODL Artwork Generator — API (apps/api) environment template
# Copy to apps/api/.env for local dev. On Render, set these in the
# dashboard (the values in render.yaml marked `sync: false`).
# NEVER commit the real .env — it is gitignored.
# ─────────────────────────────────────────────────────────────

# Supabase (REQUIRED — the server exits on startup without these)
# Project Settings → API. Use the SERVICE ROLE key here (server-only secret).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Allowed browser origin(s) for CORS — your frontend URL.
# Local: http://localhost:5173  |  Prod: https://your-app.netlify.app
# Comma-separate multiple origins if needed.
FRONTEND_URL=http://localhost:5173

# Port to bind. Locally defaults to 3001; on Render this is injected
# automatically, so you normally leave it unset in production.
PORT=3001

# Generation limits. On low-resource hosts (0.5 CPU / 512 MB) keep
# MAX_CONCURRENT_JOBS at 1 to avoid out-of-memory during rendering.
MAX_EDITION_SIZE=10000
MAX_CONCURRENT_JOBS=1

# Persistent trait cache directory. On Render, mount a disk at /var/data and set:
# ASSET_CACHE_DIR=/var/data/hodl-cache
# Without this, every instance restart re-downloads all traits (major Supabase egress).
# ASSET_CACHE_DIR=/var/data/hodl-cache

# Signed URL lifetime for gallery thumbnails (seconds). Default 7 days.
# SIGNED_URL_TTL=604800

# Generation fee verification (MultiversX mainnet USDC)
# GENERATION_PAYMENT_TOKEN=USDC-c76f1f
# GENERATION_PAYMENT_TREASURY=erd158k2c3aserjmwnyxzpln24xukl2fsvlk9x46xae4dxl5xds79g6sdz37qn
# GENERATION_PAYMENT_API_URL=https://api.multiversx.com
# GENERATION_PAYMENT_DISABLED=true
